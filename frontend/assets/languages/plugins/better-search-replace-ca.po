#: includes/class-bsr-admin.php:136
msgid "<p>During the search/replace, <strong>%1$d</strong> tables were searched, with <strong>%2$d</strong> cells changed in <strong>%3$d</strong> updates.</p><p><a href=\"%4$s\" class=\"thickbox\" title=\"Search/Replace Details\">Click here</a> for more details.</p>"
msgstr "<p>Durant la cerca/substitució, s'ha cercat en <strong>%1$d</strong> taules, amb <strong>%2$d</strong> cel·les canviades en les <strong>%3$d</strong> actualitzacions.</p><p><a href=\"%4$s\" class=\"thickbox\" title=\"Detalls de la cerca/substitució\">Feu clic aquí</a> per obtenir més informació.</p>"

#: includes/class-bsr-admin.php:125
msgid "<p><strong>DRY RUN:</strong> <strong>%1$d</strong> tables were searched, <strong>%2$d</strong> cells were found that need to be updated, and <strong>%3$d</strong> changes were made.</p><p><a href=\"%4$s\" class=\"thickbox\" title=\"Dry Run Details\">Click here</a> for more details, or use the form below to run the search/replace.</p>"
msgstr "<p><strong>SIMULACRE:</strong> s'ha cercat en <strong>%1$d</strong> taules, s'han trobat <strong>%2$d</strong> cel·les que han d'actualitzar-se i s'han fet <strong>%3$d</strong> canvis.</p><p><a href=\"%4$s\" class=\"thickbox\" title=\"Detalls del simulacre\">Feu clic aquí</a> per obtenir més detalls, o utilitzeu el següent formulari per executar la cerca/substitució.</p>"