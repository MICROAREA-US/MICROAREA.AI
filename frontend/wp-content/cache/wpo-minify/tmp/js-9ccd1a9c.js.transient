{"request":{"hurl":"https:\/\/microarea.es\/wp-content\/plugins\/newsletter\/main.js","inline":"","enable_minification":true,"type":"js","handle":"newsletter","version":"9.2.4"},"log":{"url":"\/wp-content\/plugins\/newsletter\/main.js","success":true},"code":"if(document.readyState!=='loading'){tnp_ajax_init()}else{document.addEventListener(\"DOMContentLoaded\",function(){tnp_ajax_init()})}\nfunction tnp_ajax_init(){document.querySelectorAll('form.tnp-ajax').forEach(el=>{el.addEventListener('submit',async function(ev){ev.preventDefault();ev.stopPropagation();const response=await fetch(newsletter_data.action_url+'?action=tnp&na=sa',{method:\"POST\",body:new FormData(this)});this.innerHTML=await response.text()})})};\n","status":true}