# Subdominio para el Panel de Soporte Técnico Live Chat
chat.microarea.ai {
    root * C:/www/new2.microarea.es
    encode zstd gzip

    # Redireccionar/reescribir la raíz al panel de administración del chat
    rewrite / /admin-chat.html

    # Proxificar las llamadas de la API del chat al servidor NodeJS en el puerto 3000
    reverse_proxy /api/* localhost:3000

    # Servir el archivo estático y sus recursos asociados
    file_server
}



